# cozy-adventure multiplayer server — example environment.
# Copy to .env and adjust. All values have sensible defaults; none is required.

# Network
PORT=8080
# Comma-separated allowed origins for the WS/HTTP endpoint, or * for any.
ALLOWED_ORIGINS=*

# Access control. If set, clients must supply this password in `join`.
# Leave empty for an open server (LAN / trusted friends).
SERVER_PASSWORD=

# World identity for this process (one world per server).
WORLD_ID=default
# Max concurrent players in the world.
MAX_PLAYERS=8

# Persistence. If DATABASE_URL is empty, an in-memory store is used (dev/test).
# Example: postgres://cozy:cozy@localhost:5432/cozy
DATABASE_URL=

# Tuning (milliseconds unless noted)
AVATAR_TICK_HZ=15
SAVE_INTERVAL_MS=30000
RECONNECT_WINDOW_MS=30000
KEEPALIVE_TIMEOUT_MS=60000
