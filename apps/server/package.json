{
  "name": "@cozy/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Authoritative multiplayer server (one world per process) for cozy-adventure",
  "main": "dist/index.js",
  "exports": {
    "./testing": "./test/harness/startTestServer.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@cozy/shared": "workspace:*",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
