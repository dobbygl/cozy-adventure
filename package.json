{
  "name": "cozy-adventure",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.js\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.js\" \"test/**/*.js\" \"*.{js,json,md}\"",
    "typecheck": "tsc -p jsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/three": "^0.160.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.5",
    "puppeteer-core": "^25.2.1",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3",
    "vite": "^7.2.4",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "three": "0.160.0"
  }
}
